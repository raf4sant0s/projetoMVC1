<!DOCTYPE html>
<html>
<head>
<title>Contato</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <nav class="bg-teal-400 p-4 text-white flex justify-center gap-6">
        <a href="/"><p class="hover:text-teal-700 transition">Home</p></a>
        <a href="/sobre"><p class="hover:text-teal-700 transition">Sobre</p></a>
        <a href="/contato"><p class="hover:text-teal-700 transition">Contato</p></a>
        <a href="/produtos"><p class="hover:text-teal-700 transition">Produtos</p></a>
    </nav>

    <div class="max-w-xl mx-auto mt-16 bg-white p-10 rounded shadow">

        <h1 class="text-2xl font-bold mb-6">Contato</h1>

        <form class="space-y-4">

    <div>

    <div>
        <label class="block mb-1 font-medium">Nome</label>
        <input type="text" class="w-full border p-2 rounded focus:outline-none focus:ring-2 focus:ring-teal-500"/>
    </div>

    <div>
        <label class="block mb-1 font-medium">Email</label>
        <input type="email" class="w-full border p-2 rounded focus:outline-none focus:ring-2 focus:ring-teal-500"/>
    </div>

    <div>
        <label class="block mb-1 font-medium">Mensagem</label>
        <textarea class="w-full border p-2 rounded focus:outline-none focus:ring-2 focus:ring-teal-500"></textarea>
    </div>

    <button class="bg-teal-400 text-white px-4 py-2 rounded hover:bg-teal-600">Enviar mensagem</button>


</body>
</html>