<!DOCTYPE html>
<html>
<head>
<title>Produtos</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<nav class="bg-teal-400 p-4 text-white flex justify-center gap-6">
<a href="/">Home</a>
<a href="/sobre">Sobre</a>
<a href="/contato">Contato</a>
<a href="/produtos">Produtos</a>
</nav>

<div class="max-w-3xl mx-auto mt-16 bg-white p-10 rounded shadow">

<h1 class="text-2xl font-bold mb-6">Gerenciamento de Produtos</h1>

<h2 class="text-lg font-semibold mb-3">
<%= produtoEditando ? "Editar Produto" : "Cadastrar Produto" %>
</h2>

<form
action="<%= produtoEditando ? '/atualizar/' + produtoEditando.id : '/produtos' %>"
method="POST"
class="space-y-4 mb-10"
>

<div>
<label class="block mb-1">Nome do Produto</label>

<input
type="text"
name="nome"
value="<%= produtoEditando ? produtoEditando.nome : '' %>"
required
class="w-full border p-2 rounded focus:ring-2 focus:ring-teal-500"
/>

</div>

<div>
<label class="block mb-1">Preço</label>

<input
type="number"
name="preco"
value="<%= produtoEditando ? produtoEditando.preco : '' %>"
required
class="w-full border p-2 rounded focus:ring-2 focus:ring-teal-500"
/>

</div>

<button
class="bg-teal-400 text-white px-4 py-2 rounded hover:bg-teal-600"
>

<%= produtoEditando ? "Atualizar Produto" : "Adicionar Produto" %>

</button>

</form>

<h2 class="text-lg font-semibold mb-3">Buscar Produto</h2>

<input
id="search"
placeholder="Buscar produto..."
class="w-full border p-2 rounded mb-6"
/>

<h2 class="text-lg font-semibold mb-4">Lista de Produtos</h2>

<ul id="productList" class="space-y-2">

<% produtos.forEach(produto => { %>

<li class="flex justify-between items-center border p-3 rounded">

<span class="product-name">
<%= produto.nome %> - R$ <%= produto.preco %>
</span>

<div class="flex gap-3">

<a
href="/editar/<%= produto.id %>"
class="text-blue-600 hover:underline"
>
Editar
</a>

<a
href="/excluir/<%= produto.id %>"
onclick="return confirm('Tem certeza que deseja excluir este produto?')"
class="text-red-600 hover:underline"
>
Excluir
</a>

</div>

</li>

<% }) %>

</ul>

</div>

<script>

const search = document.getElementById("search")
const products = document.querySelectorAll("#productList li")

search.addEventListener("keyup", function() {

const value = search.value.toLowerCase()

products.forEach(product => {

const text = product.innerText.toLowerCase()

product.style.display =
text.includes(value) ? "flex" : "none"

})

})

</script>

</body>
</html>